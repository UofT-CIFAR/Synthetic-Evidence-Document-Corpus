    "inputs": {"ckpt_name": "sd3_medium_incl_clips_t5xxlfp8.safetensors"}
  },
  "20": {
    "class_type": "EmptySD3LatentImage",
    "inputs": {"width": "<<WIDTH>>", "height": "<<HEIGHT>>", "batch_size": 1}
  },
  "30": {
    "class_type": "CLIPTextEncode",
    "inputs": {"text": "<<PROMPT>>", "clip": ["10", 1]}
  },
  "31": {
    "class_type": "CLIPTextEncode",
    "inputs": {"text": "", "clip": ["10", 1]}
  },
  "40": {
    "class_type": "KSampler",
    "inputs": {
      "model": ["10", 0],
      "seed": "<<SEED>>",
      "steps": 28,
      "cfg": 4.5,
      "sampler_name": "euler",
      "scheduler": "sgm_uniform",
      "denoise": 1.0,
      "positive": ["30", 0],
      "negative": ["31", 0],
      "latent_image": ["20", 0]
    }
  },
  "50": {
    "class_type": "VAEDecode",
    "inputs": {"samples": ["40", 0], "vae": ["10", 2]}
  },
  "99": {
